  "shortcuts": [
    {
      "name": "Log Medication",
      "short_name": "Log Med",
      "description": "Quickly log your medication",
      "url": "/log?tab=med",
      "icons": [{ "src": "/icon-96x96.png", "sizes": "96x96" }]
    },
    {
      "name": "Log Vitals",
      "short_name": "Log Vitals",
      "description": "Record your vitals",
      "url": "/log?tab=vitals",
      "icons": [{ "src": "/icon-96x96.png", "sizes": "96x96" }]
